{
  "uid": "transactiq-overview",
  "title": "TransactIQ — Overview",
  "tags": ["transactiq"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "Throughput (payments/sec)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(transactiq_payments_accepted_total[1m]))", "legendFormat": "accepted (gateway)" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(transactiq_payments_processed_total[1m]))", "legendFormat": "processed (processor)" }
      ]
    },
    {
      "id": 2,
      "title": "Processing latency (p50 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(transactiq_processing_seconds_bucket[5m])) by (le))", "legendFormat": "p50" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(transactiq_processing_seconds_bucket[5m])) by (le))", "legendFormat": "p99" }
      ]
    },
    {
      "id": 3,
      "title": "Gateway create latency (p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(transactiq_gateway_create_seconds_bucket[5m])) by (le))", "legendFormat": "p99" }
      ]
    },
    {
      "id": 4,
      "title": "HTTP error rate (%)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "100 * (sum(rate(http_server_requests_seconds_count{status=~\"5..\"}[1m])) or vector(0)) / clamp_min(sum(rate(http_server_requests_seconds_count[1m])), 1)", "legendFormat": "5xx %" }
      ]
    },
    {
      "id": 5,
      "title": "Kafka consumer lag (payment-processor)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max(kafka_consumer_fetch_manager_records_lag_max{application=\"payment-processor\"})", "legendFormat": "max lag (records)" }
      ]
    },
    {
      "id": 6,
      "title": "Fraud outcomes / sec (by status)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (status) (rate(transactiq_payments_processed_total[1m]))", "legendFormat": "{{status}}" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(transactiq_events_duplicate_total[5m]))", "legendFormat": "duplicates skipped" },
        { "refId": "C", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(transactiq_events_dlq_total[5m]))", "legendFormat": "DLQ (5m)" }
      ]
    }
  ]
}
