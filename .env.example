# Copy to `.env` and adjust as needed. `.env` is git-ignored.
# docker-compose reads these; defaults are baked into docker-compose.yml so `up` works
# even without a .env file.

# --- MySQL ---
MYSQL_ROOT_PASSWORD=rootpw
MYSQL_DATABASE=transactiq
MYSQL_USER=transactiq
MYSQL_PASSWORD=transactiq

# --- Grafana ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# --- Service ports (informational; configured in each service's application.yml) ---
# payment-gateway   -> 8080
# payment-processor -> 8081
# fraud-service     -> 8082

# --- Infra ports (informational; configured in docker-compose.yml) ---
# kafka       -> 9092
# mysql       -> 3307 (host) -> 3306 (container)  [3307 avoids clashing with a local MySQL]
# redis       -> 6379
# prometheus  -> 9090
# grafana     -> 3000
